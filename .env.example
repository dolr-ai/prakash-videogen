# videogen-worker API
PORT=8288
BACKEND_TYPE=comfyui
AUTH_TOKEN=your-bearer-token-here

# ComfyUI connection (local on Vast.ai)
COMFYUI_HOST=127.0.0.1
COMFYUI_PORT=8188
COMFYUI_OUTPUT_DIR=/workspace/ComfyUI/output

# Cloudflare tunnel
CF_TUNNEL_TOKEN=your-tunnel-token-from-cloudflare-dashboard

# Observability
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
RUST_LOG=info,videogen_worker=debug
